# Copy this file to `.env` and fill in real credentials for integration testing.
#
# Unit/model tests run against captured fixtures and need NONE of these.
# Integration tests (tests/integration/) auto-skip when the vars they need
# are missing, so you only have to fill in the tracker(s) you have an account for.
#
# An API key alone is enough for most integration tests and for
# devtools/capture_fixtures.py. The USERNAME/PASSWORD pairs are only needed
# by the login-flow (*_credentials) fixtures.

# Orpheus.network
ORPHEUS_API_KEY=your_orpheus_api_key
ORPHEUS_USERNAME=your_orpheus_username
ORPHEUS_PASSWORD=your_orpheus_password

# Redacted.ch
REDACTED_API_KEY=your_redacted_api_key
REDACTED_USERNAME=your_redacted_username
REDACTED_PASSWORD=your_redacted_password